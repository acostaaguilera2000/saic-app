extends layout

block content
  //- Botones de Acción Rápida
  .d-flex.gap-2.mb-4.overflow-auto.pb-2
    button.btn.btn-action.shadow-sm.px-4.text-nowrap 
      i.bi.bi-plus-lg.me-2
      | Nuevo Miembro
    button.btn.btn-action.shadow-sm.px-4.text-nowrap 
      i.bi.bi-cash-coin.me-2
      | Registrar Ofrenda
    button.btn.btn-action.shadow-sm.px-4.text-nowrap 
      i.bi.bi-megaphone.me-2
      | Crear Comunicado

  //- Fila de Tarjetas de Métricas
  .row.g-4.mb-4
    //- Total Usuarios
    .col-xl-3.col-md-6
      .card.card-custom.p-4.border-bottom.border-primary.border-5.h-100
        span.text-muted.small.fw-bold.text-uppercase Total Usuarios
        h2.fw-bold.mt-2.mb-0 1,520
        small.text-success
          i.bi.bi-arrow-up.me-1
          | 8.5% esta semana
    
    //- Activos
    .col-xl-3.col-md-6
      .card.card-custom.p-4.border-bottom.border-success.border-5.h-100
        span.text-muted.small.fw-bold.text-uppercase Activos
        h2.fw-bold.mt-2.mb-0 1,405
        .progress.mt-3(style="height: 6px;")
          .progress-bar.bg-success(role="progressbar" style="width: 92%" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100")
    
    //- Inactivos
    .col-xl-3.col-md-6
      .card.card-custom.p-4.border-bottom.border-danger.border-5.h-100
        span.text-muted.small.fw-bold.text-uppercase Inactivos
        h2.fw-bold.mt-2.mb-0 115
        small.text-muted Requieren seguimiento
    
    //- Crecimiento
    .col-xl-3.col-md-6
      .card.card-custom.p-4.border-bottom.border-warning.border-5.h-100
        span.text-muted.small.fw-bold.text-uppercase Crecimiento
        h2.fw-bold.mt-2.mb-0 +12%
        small.text-muted Promedio mes actual

  //- Fila del Gráfico
  .row.mb-4
    .col-12
      .card.card-custom.p-4
        .d-flex.justify-content-between.align-items-center.mb-3
          h6.fw-bold.mb-0 Análisis de Crecimiento Mensual
          select.form-select.form-select-sm(style="width: 120px;")
            option(selected) 2026
            option 2025
        div(style="height: 300px;")
          canvas#growthChart

  //- Fila Inferior: Eventos y Nuevos Ingresos
  .row.g-4
    //- Sección de Eventos
    .col-xl-6
      .card.card-custom.p-4.h-100
        .d-flex.justify-content-between.align-items-center.mb-4
          h5.fw-bold.mb-0 Próximos Eventos
          a.btn.btn-sm.btn-outline-secondary(href="#") Ver todo
        
        //- Evento 1
        .event-card.shadow-sm
          .date-box
            span.fw-bold.d-block.text-primary 15
            small ABR
          .flex-grow-1
            h6.mb-0.fw-bold Culto Especial de Oración
            small.text-muted
              i.bi.bi-geo-alt.me-1
              | Auditorio Principal
          span.badge.bg-success-subtle.text-success.border.border-success Confirmado
        
        //- Evento 2
        .event-card.shadow-sm
          .date-box
            span.fw-bold.d-block.text-primary 22
            small ABR
          .flex-grow-1
            h6.mb-0.fw-bold Cena Ministerial
            small.text-muted
              i.bi.bi-geo-alt.me-1
              | Salón de Eventos B
          span.badge.bg-warning-subtle.text-warning.border.border-warning Pendiente

    //- Sección de Nuevos Ingresos
    .col-xl-6
      .card.card-custom.p-4.h-100
        .d-flex.justify-content-between.align-items-center.mb-4
          h5.fw-bold.mb-0 Nuevos Ingresos
          span.badge.rounded-pill.bg-primary-subtle.text-primary Últimos 7 días
        
        .list-group.list-group-flush
          //- Usuario 1
          .list-group-item.px-0.border-0.mb-3.d-flex.align-items-center
            img.rounded-circle.me-3(src="https://ui-avatars.com/api/?name=Ana+Gomez&background=002855&color=fff" width="50" alt="Avatar")
            .flex-grow-1
              h6.mb-0.fw-bold Ana María Gómez
              small.text-muted Ministerio de Niños
            button.btn.btn-sm.btn-light.border
              i.bi.bi-three-dots
          
          //- Usuario 2
          .list-group-item.px-0.border-0.mb-3.d-flex.align-items-center
            img.rounded-circle.me-3(src="https://ui-avatars.com/api/?name=Pedro+Soto&background=D4AF37&color=fff" width="50" alt="Avatar")
            .flex-grow-1
              h6.mb-0.fw-bold Pedro Soto
              small.text-muted Ministerio de Alabanza
            button.btn.btn-sm.btn-light.border
              i.bi.bi-three-dots
          
          //- Usuario 3
          .list-group-item.px-0.border-0.d-flex.align-items-center
            img.rounded-circle.me-3(src="https://ui-avatars.com/api/?name=Lucia+Rivas&background=003a7a&color=fff" width="50" alt="Avatar")
            .flex-grow-1
              h6.mb-0.fw-bold Lucía Rivas
              small.text-muted Escuela Dominical
            button.btn.btn-sm.btn-light.border
              i.bi.bi-three-dots

block scripts
  script(src="https://cdn.jsdelivr.net/npm/chart.js")
  script(src="/js/charts-dashboard.js")