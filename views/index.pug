doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title SAIC - Software Administrativo para Iglesias Cristianas
    
    //- Bootstrap 5 CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    //- Google Fonts
    link(href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap" rel="stylesheet")
    
    style.
      :root {
        --saic-blue: #0033a0;
        --saic-gold: #ffb81c;
        --saic-dark: #1a1a1a;
      }
      body { font-family: 'Roboto', sans-serif; }
      .navbar { border-bottom: 3px solid var(--saic-gold); }
      .navbar-brand { font-weight: bold; color: var(--saic-blue) !important; }
      .hero {
        background: linear-gradient(rgba(0, 51, 160, 0.9), rgba(0, 51, 160, 0.8)), 
                    url('https://images.unsplash.com/photo-1438232992991-995b7058bbb3?auto=format&fit=crop&q=80&w=1920') no-repeat center center/cover;
        color: white;
        padding: 100px 0;
        text-align: center;
      }
      .hero p { color: var(--saic-gold); }
      .btn-primary { background-color: var(--saic-gold); border-color: var(--saic-gold); color: #000; font-weight: bold; }
      .btn-primary:hover { background-color: #e5a517; border-color: #e5a517; }
      .feature-icon { font-size: 2.5rem; color: var(--saic-blue); margin-bottom: 1rem; }
      .card { border: none; transition: transform 0.3s; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
      .card:hover { transform: translateY(-10px); }
      footer { background-color: var(--saic-dark); color: white; padding: 50px 0; }

  body
    //- Navegación
    nav.navbar.navbar-expand-lg.sticky-top.bg-white
      .container
        a.navbar-brand(href="#")
          span(style="font-size: 1.5rem;") SAIC
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item: a.nav-link(href="#inicio") Inicio
            li.nav-item: a.nav-link(href="#funciones") Funciones
            li.nav-item: a.nav-link(href="#contacto") Contacto
            li.nav-item: a.btn.btn-primary.ms-lg-3(href="/auth/login") Login

    //- Hero Section
    header#inicio.hero
      .container
        h1.display-4.fw-bold Gestión Eficiente para tu Iglesia
        p.lead.mb-4 Software Administrativo para Iglesias Cristianas: Orden, Transparencia y Crecimiento.
        .d-grid.gap-2.d-sm-flex.justify-content-sm-center
          a.btn.btn-primary.btn-lg.px-4.gap-3(href="#contacto") Empezar Ahora
          button.btn.btn-outline-light.btn-lg.px-4(type="button") Saber más

    //- Características
    section#funciones.py-5
      .container
        .text-center.mb-5
          h2.fw-bold Todo lo que tu congregación necesita
          .mx-auto(style="width: 60px; height: 3px; background: var(--saic-gold);")
        
        .row.g-4.text-center
          //- Mixin para tarjetas (reutilización)
          mixin feature(icon, title, text)
            .col-md-4
              .card.h-100.p-4
                .feature-icon #{icon}
                h3 #{title}
                p #{text}

          +feature("👥", "Membresía", "Control detallado de miembros, bautismos, ministerios y grupos familiares.")
          +feature("💰", "Finanzas", "Gestión transparente de diezmos, ofrendas y reportes contables automáticos.")
          +feature("📅", "Eventos", "Calendario de actividades y control de asistencia a servicios y reuniones.")

    //- Contacto
    section#contacto.py-5.bg-light
      .container
        .row.align-items-center
          .col-lg-6
            h2.fw-bold Lleva tu administración al siguiente nivel
            p Déjanos tus datos y un asesor te contactará para una demostración personalizada del sistema SAIC.
          .col-lg-6
            .bg-white.p-4.rounded.shadow
              form
                .mb-3
                  label.form-label Nombre de la Iglesia
                  input.form-control(type="text" placeholder="Ej. Iglesia Central")
                .mb-3
                  label.form-label Correo Electrónico
                  input.form-control(type="email" placeholder="nombre@correo.com")
                button.btn.btn-primary.w-100(type="submit") Solicitar Información

    //- Footer
    footer.text-center
      .container
        h3.mb-4 SAIC
        p Software Administrativo para Iglesias Cristianas
        hr.my-4.bg-secondary
        p.small.text-muted &copy; 2026 SAIC. Todos los derechos reservados.

    //- Bootstrap JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")