doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title || "SAIC - Software Administrativo para Iglesias Cristianas"}
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")

    style.
      body {
        background-color: #EDF6F9; /* Gris claro */
        font-family: 'Segoe UI', sans-serif;
      }
      .navbar-custom {
        background-color: #006D77; /* Teal principal */
      }
      .footer-custom {
        background-color: #006D77;
      }
      .btn-custom {
        background-color: #FF6F61; /* Coral suave */
        border: none;
      }
      .btn-custom:hover {
        background-color: #e85c55;
      }
      h1, h2, h5 {
        color: #006D77;
      }
      p {
        color: #333;
      }

  body
    // Menú de navegación
    nav.navbar.navbar-expand-lg.navbar-dark.navbar-custom
      .container
        a.navbar-brand.fw-bold(href="/") SAIC
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/") Inicio
            li.nav-item
              a.nav-link(href="/nosotros") Nosotros
            li.nav-item
              a.nav-link(href="/auth/login") Login

    // Contenido principal tipo landing
    main.container.mt-5
      .row.align-items-center
        .col-md-6
          h1.fw-bold Bienvenido a SAIC
          p.lead.mt-3 El software administrativo diseñado para iglesias cristianas, con confianza y frescura institucional.
          a.btn.btn-custom.btn-lg.mt-3.text-white(href="/dashboard") Comenzar ahora
        .col-md-6
          img.img-fluid.rounded(
            src="/img/computador.jpg", 
            alt="Iglesia cristiana"
          )


  // Sección adicional
  section.container.mt-5
    h2.text-center.mb-4 ¿Por qué elegir SAIC?
    .row.text-center
      .col-md-4
        i.bi.bi-people-fill.text-teal.fs-1(style="color:#006D77;")
        h5.mt-2 Gestión de miembros
        p Administra la información de tu congregación con orden y claridad.
      .col-md-4
        i.bi.bi-shield-lock-fill.text-success.fs-1(style="color:#006D77;")
        h5.mt-2 Seguridad
        p Tus datos están protegidos con autenticación avanzada y respaldo seguro.
      .col-md-4
        i.bi.bi-bar-chart-fill.text-warning.fs-1(style="color:#FF6F61;")
        h5.mt-2 Reportes claros
        p Obtén estadísticas y reportes confiables para una mejor administración.

  // Footer
  footer.footer-custom.text-white.text-center.py-4.mt-5
    p.mb-0.text-white © 2026 SAIC - Software Administrativo para Iglesias Cristianas

  // Bootstrap JS
  script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
