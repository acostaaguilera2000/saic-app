extends ../layout

block content
  .container.mt-4
    .d-flex.flex-wrap.justify-content-between.align-items-center.mb-3
      h1.text-dark.mb-2 Lista de Usuarios
      a.btn.btn-sm.btn-warning.text-white.fw-bold(href="/users/create")
        i.bi.bi-person-plus-fill.me-2
        | Crear Usuario

    .table-responsive.rounded
      table.table.table-hover.align-middle.mb-0
        thead
          tr
            th ID
            th Usuario
            th Email
            th Rol
            th Miembro asociado
            th Acciones
        tbody
          each usuario in usuarios
            - var iniciales = (usuario.nombre ? usuario.nombre.charAt(0) : '') + (usuario.apellido ? usuario.apellido.charAt(0) : '')
            tr
              td= usuario.id_usuario
              td
                .d-flex.align-items-center
                  span.avatar-initial.bg-primary.me-2 #{iniciales || 'EX'}
                  .flex-grow-1
                    strong.d-block #{usuario.username || '—'}
                    small.text-muted #{usuario.nombre && usuario.apellido ? usuario.nombre + ' ' + usuario.apellido : 'Externo'}
              td= usuario.email
              td
                span.badge.bg-warning.text-dark.fw-semibold #{usuario.rol}
              td= usuario.nombre && usuario.apellido ? usuario.nombre + ' ' + usuario.apellido : 'Externo'
              td
                .d-flex.flex-wrap.gap-2
                  a.btn.btn-sm.btn-primary.text-white(href=`/users/update/${usuario.id_usuario}`)
                    i.bi.bi-pencil-fill.me-1
                    
                  a.btn.btn-sm.btn-danger.text-white(href=`/users/delete/${usuario.id_usuario}`)
                    i.bi.bi-trash-fill.me-1
                    
