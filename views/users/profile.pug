extends ../layout

block content


    //- Contenedor Principal
    .row.justify-content-center
        .col-lg-8

            //- Tarjeta de Perfil
            .card.border-0.shadow-sm
                .card-header.bg-white.py-3.border-bottom
                    .d-flex.align-items-center
                        i.bi.bi-person-circle.text-primary.me-2.fs-5
                        h5.mb-0.fw-bold Mi Cuenta

                .card-body.p-4
                    form(action="/users/profile/update" method="POST")
                        .row.g-3
                            //- Encabezado de Usuario
                            .col-md-12.text-center.mb-4
                                .bg-primary.text-white.rounded-circle.d-inline-flex.align-items-center.justify-content-center.shadow-sm(style="width: 80px; height: 80px; font-size: 2rem;")
                                    | #{user.username.charAt(0).toUpperCase()}
                                h4.mt-3.fw-bold.mb-1= user.username
                                span.badge.rounded-pill.bg-primary-subtle.text-primary.px-3= user.rol.toUpperCase()

                            //- Datos de Usuario
                            .col-md-6
                                label.form-label.fw-semibold.small.text-muted Correo Electrónico
                                input.form-control.bg-light(type="email" value=user.email disabled)
                                small.text-muted.x-small El correo no es modificable.

                            .col-md-6
                                label.form-label.fw-semibold.small.text-muted Nombre de Usuario
                                input.form-control(type="text" name="username" value=user.username required)

                            //- Sección de Seguridad
                            .col-12.mt-5
                                .d-flex.align-items-center.mb-2
                                    i.bi.bi-shield-lock.text-primary.me-2
                                    h6.mb-0.fw-bold Cambiar Contraseña
                                hr.mt-0

                            .col-md-6
                                label.form-label.fw-semibold.small.text-muted Nueva Contraseña
                                input.form-control(type="password" name="newPassword" placeholder="Mínimo 6 caracteres")
                                small.text-muted.x-small Dejar en blanco para no cambiar.

                            .col-md-6
                                label.form-label.fw-semibold.small.text-muted Confirmar Contraseña
                                input.form-control(type="password" name="confirmPassword" placeholder="Repita la contraseña")

                            //- Botones de Acción
                            .col-12.text-end.mt-4.pt-3.border-top
                                a.btn.btn-light.px-4.me-2(href="/dashboard") Cancelar
                                button.btn.btn-primary.px-5.shadow-sm(type="submit")
                                    i.bi.bi-save.me-2
                                    | Guardar Cambios