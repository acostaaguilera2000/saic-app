extends ../layout

block content
  .row.justify-content-center
    .col-lg-10
      //- Cabecera con navegación y contexto
      .d-flex.align-items-center.justify-content-between.mb-4
        div
          .d-flex.align-items-center.gap-3
            img.rounded-circle.shadow-sm(
              src=`https://ui-avatars.com/api/?name=${userToEdit.username}&background=D4AF37&color=fff&size=48` 
              alt="Avatar"
            )
            div
              h2.fw-bold.text-dark.mb-0 Editar Perfil
              p.text-muted.small.mb-0 Modificando la cuenta de: 
                strong.text-primary #{userToEdit.username}
        
        a.btn.btn-outline-secondary.btn-sm.rounded-pill.px-3(href="/users")
          i.bi.bi-arrow-left.me-2
          | Volver

      .card.card-custom.border-0.shadow-sm
        .card-body.p-4.p-md-5
          form(action=`/users/update/${userToEdit.id_usuario}` method="POST")
            .row.g-4
              //- Sección: Datos de Cuenta
              .col-12
                .d-flex.align-items-center.mb-2
                  i.bi.bi-gear-wide-connected.text-primary.me-2
                  span.fw-bold.text-uppercase.small.text-muted Configuración de Cuenta
                hr.mt-0.mb-4

              .col-md-6
                label.form-label.fw-semibold(for="username") Nombre de Usuario
                .input-group
                  span.input-group-text.bg-light: i.bi.bi-person
                  input.form-control.bg-light(
                    type="text" 
                    id="username" 
                    name="username" 
                    value=userToEdit.username
                  )

              .col-md-6
                label.form-label.fw-semibold(for="email") Correo Electrónico
                .input-group
                  span.input-group-text.bg-light: i.bi.bi-envelope
                  input.form-control.bg-light(
                    type="email" 
                    id="email" 
                    name="email" 
                    value=userToEdit.email
                  )

              .col-md-6
                label.form-label.fw-semibold(for="password") Nueva Contraseña
                .input-group
                  span.input-group-text.bg-light: i.bi.bi-shield-lock
                  input.form-control.bg-light(
                    type="password" 
                    id="password" 
                    name="password" 
                    placeholder="Dejar en blanco para no cambiar"
                  )
                small.text-muted.mt-1 Solo si deseas actualizar el acceso.

              .col-md-6
                label.form-label.fw-semibold(for="rol") Nivel de Permisos
                .input-group
                  span.input-group-text.bg-light: i.bi.bi-layers
                  select.form-select.bg-light(id="rol" name="rol")
                    option(value="admin" selected=(userToEdit.rol==="admin")) Administrador
                    option(value="tesorero" selected=(userToEdit.rol==="tesorero")) Tesorero
                    option(value="lider" selected=(userToEdit.rol==="lider")) Líder Ministerial
                    option(value="miembro" selected=(userToEdit.rol==="miembro")) Miembro General

              //- Sección: Miembro Vinculado
              .col-12.mt-5
                .d-flex.align-items-center.mb-2
                  i.bi.bi-person-vcard.text-primary.me-2
                  span.fw-bold.text-uppercase.small.text-muted Vinculación de Identidad
                hr.mt-0.mb-4

              .col-12
                label.form-label.fw-semibold Miembro Asociado
                if userToEdit.id_miembro
                  .alert.bg-primary-subtle.border-primary-subtle.d-flex.align-items-center.justify-content-between
                    .d-flex.align-items-center
                      i.bi.bi-info-circle-fill.text-primary.me-3.fs-4
                      div
                        span.d-block.fw-bold.text-primary #{userToEdit.nombre_miembro} #{userToEdit.apellido_miembro}
                        small.text-muted.text-uppercase Vinculación protegida
                    input(type="hidden" name="id_miembro" value=userToEdit.id_miembro)
                else
                  .input-group
                    span.input-group-text.bg-light: i.bi.bi-people
                    select.form-select.bg-light(id="id_miembro" name="id_miembro")
                      option(value="") Sin asignar (Externo)
                      if miembros && miembros.length
                        each miembro in miembros
                          option(
                            value=miembro.id_miembro 
                            selected=(miembro.id_miembro===userToEdit.id_miembro)
                          )= `${miembro.nombre} ${miembro.apellido}`

            //- Botones Finales
            .d-flex.justify-content-end.gap-3.mt-5
              a.btn.btn-light.px-4(href="/users") Cancelar
              button.btn.btn-action.px-5.shadow-sm(type="submit")
                i.bi.bi-save.me-2
                | Guardar Cambios