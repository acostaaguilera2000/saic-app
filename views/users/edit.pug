extends ../layout

block content
  .container.mt-4
    .card.border-0
      .card-header.text-white(style="background-color: #1E3A8A;")
        h4.mb-0 Editar Usuario
      .card-body
        if errores && errores.length
          .alert.alert-danger
            h5.mb-2 Errores de validación:
            ul.mb-0
              each error in errores
                li= error

        form(action=`/users/update/${userToEdit.id_usuario}` method="POST")
          .row
            .col-md-6.mb-3
              label.form-label(for="username") Username
              input.form-control(
                type="text"
                id="username"
                name="username"
                value=userToEdit.username
                placeholder="Ingrese nombre de usuario"
              )

            .col-md-6.mb-3
              label.form-label(for="email") Email
              input.form-control(
                type="email"
                id="email"
                name="email"
                value=userToEdit.email
                placeholder="ejemplo@correo.com"
              )

          .row
            .col-md-6.mb-3
              label.form-label(for="password") Nueva Contraseña (opcional)
              input.form-control(
                type="password"
                id="password"
                name="password"
                placeholder="Ingrese nueva contraseña"
              )

            .col-md-6.mb-3
              label.form-label(for="rol") Rol
              select.form-select(id="rol" name="rol")
                option(value="admin" selected=(userToEdit.rol==="admin")) Admin
                option(value="tesorero" selected=(userToEdit.rol==="tesorero")) Tesorero
                option(value="lider" selected=(userToEdit.rol==="lider")) Líder
                option(value="miembro" selected=(userToEdit.rol==="miembro")) Miembro

          .row
            .col-md-12.mb-3
              label.form-label(for="id_miembro") Miembro asociado
              if userToEdit.id_miembro
                input.form-control(
                  type="text"
                  readonly
                  value=`${userToEdit.nombre_miembro} ${userToEdit.apellido_miembro}`
                )
                input(type="hidden" name="id_miembro" value=userToEdit.id_miembro)
              else
                select.form-select(id="id_miembro" name="id_miembro")
                  option(value="") Ninguno
                  if miembros && miembros.length
                    each miembro in miembros
                      option(
                        value=miembro.id_miembro 
                        selected=(miembro.id_miembro===userToEdit.id_miembro)
                      )= miembro.nombre + ' ' + miembro.apellido

          .d-flex.justify-content-between.mt-4
            a.btn.btn-outline-secondary.fw-bold(href="/users/list")
              i.bi.bi-arrow-left.me-2
              | Cancelar
            button.btn.btn-warning.text-white.fw-bold(type="submit")
              i.bi.bi-check-circle.me-2
              | Guardar Cambios
