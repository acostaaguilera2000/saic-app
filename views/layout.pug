doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title #{title || "Panel de Gestión"}
    // Bootstrap 
    link(rel="stylesheet" href="/css/bootstrap.min.css")
    // Bootstrap Icons
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    // estilos personalizados desde carpeta public
    link(rel="stylesheet" href="/css/styles.css")

  body
    // Menú superior
    nav.navbar.navbar-expand-lg.fixed-top.topbar
      .container-fluid.d-flex.justify-content-between
        .d-flex.flex-column.align-items-start
          button.btn.btn-link.text-dark.me-2#toggleSidebar
            i.bi.bi-list.fs-3
          span.fw-bold.text-truncate.fs-5.d-none.d-sm-block(style="max-width: 300px; line-height: 1.2;") ¡Hola, #{user.username}! 
          small.text-secondary.text-truncate.d-none.d-sm-block(style="max-width: 300px;") Bienvenido al Panel de Gestión SAIC

        // Menu desplegable usuario
        .dropdown
          a.d-flex.align-items-center.text-decoration-none.dropdown-toggle(
            href="#", id="userMenu", data-bs-toggle="dropdown", aria-expanded="false", style="color: #0033a0;")
            i.bi.bi-person-circle.fs-4.me-2
            span #{user.username}
          ul.dropdown-menu.dropdown-menu-end(aria-labelledby="userMenu")
            li
              a.dropdown-item(href="#")
                i.bi.bi-key  Cambiar contraseña
            li
              a.dropdown-item(href="#")
                i.bi.bi-gear  Configuraciones
            li
              hr.dropdown-divider
            li
              a.dropdown-item.text-danger(href="/auth/logOut")
                i.bi.bi-box-arrow-right  Salir

    // Overlay
    .overlay#overlay

    .sidebar#sidebarMenu
      .text-center.p-3.border-bottom
        i.bi.bi-person-circle.fs-1
        h6.mt-2.mb-0.text-white #{user.username}
        small.text-light #{user.rol}
      h6.text-uppercase.px-3.mt-3.text-secondary Navegación
      ul.nav.flex-column
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-house-door
            | Inicio
        li.nav-item
          a.nav-link(href="/users/list")
            i.bi.bi-person-plus-fill 
            | Usuarios
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-people 
            | Miembros
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-calendar-event 
            | Eventos 
            span.badge.bg-light.text-dark.ms-2 4
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-bank
            | Ministerios
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-cash-stack
            | Finanzas
        li.nav-item
          a.nav-link(href="#")
            i.bi.bi-megaphone
            | Comunicados

    // Contenido principal dinámico
    main.container-fluid.mt-5.main-content
      block content

    // JS
    script(src="/js/bootstrap.bundle.js")
    script(src="/js/main.js")
