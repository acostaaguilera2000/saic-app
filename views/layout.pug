doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title SAIC - App
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/dashboard.css")
  body
    //- Sidebar Escritorio
    aside.sidebar.d-none.d-lg-block
      .sidebar-header
        h3.fw-bold.mb-0(style="color: var(--saic-gold);") SAIC
        small.opacity-75.text-uppercase Admin Church
      .mt-4
        nav.nav.flex-column
          a.nav-link(href="/dashboard" class=(title==='Panel de control' ? 'active' : ''))
            i.bi.bi-grid-1x2-fill.me-3
            | Dashboard
          a.nav-link(href="/users")
            i.bi.bi-person-gear.me-3
            | Usuarios
          a.nav-link(href="#")
            i.bi.bi-people-fill.me-3
            | Miembros
          a.nav-link(href="#")
            i.bi.bi-calendar3.me-3
            | Eventos
          a.nav-link(href="#")
            i.bi.bi-diagram-3.me-3
            | Ministerios
          a.nav-link(href="#")
            i.bi.bi-wallet2.me-3
            | Finanzas
          a.nav-link(href="#")
            i.bi.bi-chat-left.me-3
            | Comunicados
          
          

    .main-wrapper
      //- Header
      header.top-header
        h5.mb-0.fw-semibold.text-muted.d-none.d-md-block Bienvenido al sistema, 
          span.text-dark #{user ? user.username : 'Administrador'}
        h5.mb-0.fw-bold.d-md-none(style="color: var(--saic-blue);") SAIC

        .dropdown
          .d-flex.align-items-center.gap-3(style="cursor: pointer;" data-bs-toggle="dropdown")
            .text-end.d-none.d-sm-block
              p.mb-0.fw-bold.lh-1(style="color: var(--saic-blue);") #{user ? user.username : 'Manuel Acosta'}
              small.text-muted #{user ? user.rol : 'Super Admin'}
            img.rounded-circle.shadow-sm(src=`https://ui-avatars.com/api/?name=${user ? user.username : 'Manuel+Acosta'}&background=003a7a&color=fff` width="45")
          ul.dropdown-menu.dropdown-menu-end.border-0.shadow.mt-3
            li: a.dropdown-item.py-2(href="#"): i.bi.bi-person.me-2 Mi Cuenta
            li: hr.dropdown-divider
            li: a.dropdown-item.py-2.text-danger(href="/auth/logout"): i.bi.bi-box-arrow-right.me-2 Salir

      //- Contenido principal
      .content-body
        block content

    //- Nav Móvil
    nav.mobile-bottom-nav.d-lg-none.py-2
      .d-flex.justify-content-around.align-items-center
        a.text-white.text-decoration-none.small.text-center(href="/dashboard")
          i.bi.bi-house-door.d-block.fs-4
          | Inicio
        a.text-white.text-decoration-none.small.text-center(href="#")
          i.bi.bi-people.d-block.fs-4
          | Miembros
        .dropup
          a.text-white.text-decoration-none.small.text-center.dropdown-toggle(data-bs-toggle="dropdown")
            i.bi.bi-plus-circle.d-block.fs-4(style="color: var(--saic-gold);")
            | Más
          ul.dropdown-menu.dropdown-menu-end.shadow.border-0.mb-3
            li: a.dropdown-item(href="#") Eventos
            li: a.dropdown-item(href="#") Usuarios

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    block scripts
     